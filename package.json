{
  "name": "rad-touristik-club-koln-e-v-1972.github.io",
  "version": "1.0.0",
  "description": "Website des RTC-Köln Radsport Klubs",
  "productName": "RTC Köln e.V. 1972",
  "author": "Martin Dünkelmann <nc-duenkekl3@netcologne.de>",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "private": true,
  "scripts": {
    "build": "quasar build",
    "predev": "corepack use pnpm@latest && pnpm lint",
    "dev": "quasar dev",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "quasar prepare",
    "lint": "pnpm lint:ts && pnpm lint:prettier",
    "lint:ts": "eslint --cache --cache-location node_modules/.cache/.eslintcache --fix .",
    "lint:prettier": "prettier --cache --cache-location node_modules/.cache/.prettiercache --ignore-path .gitignore --list-different --write '**/*.{js,ts,vue,scss,html,md,json}' .",
    "prepare": "husky",
    "test": "echo \"No test specified\" && exit 0"
  },
  "dependencies": {
    "@maz-ui/themes": "4.9.2",
    "@maz-ui/translations": "4.9.2",
    "@quasar/extras": "2.0.1",
    "@quasar/quasar-ui-qcalendar": "4.1.2",
    "@yeger/vue-masonry-wall": "6.1.1",
    "date-holidays": "3.30.2",
    "german-metadata": "2.0.1",
    "jspdf": "4.2.1",
    "libphonenumber-js": "1.13.6",
    "maz-ui": "4.9.3",
    "mime": "4.1.0",
    "pinia": "3.0.4",
    "qr-code-styling": "1.9.2",
    "quasar": "2.20.1",
    "signature_pad": "5.1.3",
    "vue": "3.5.38",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/js": "10.0.1",
    "@quasar/app-vite": "2.6.2",
    "@quasar/quasar-app-extension-qcalendar": "4.1.2",
    "@types/node": "25.9.3",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.8.0",
    "@vue/language-server": "3.3.5",
    "autoprefixer": "10.5.0",
    "commitlint": "21.0.2",
    "eslint": "10.5.0",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "vite-plugin-checker": "0.14.4",
    "vite-plugin-sitemap": "0.8.2",
    "vue-tsc": "3.3.5"
  },
  "lint-staged": {
    "*.**": [
      "eslint --fix",
      "prettier --ignore-unknown --write"
    ]
  },
  "browserslist": [
    "defaults"
  ]
}
